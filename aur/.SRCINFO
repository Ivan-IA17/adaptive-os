	optdepends = whisper.cpp: voice interface (speech-to-text)
	optdepends = espeak-ng: text-to-speech responses
	optdepends = alsa-utils: microphone recording for voice interface
	optdepends = hyprland: Wayland compositor with per-profile configs
	optdepends = waybar: status bar with per-profile configs
	optdepends = rofi-wayland: app launcher with per-profile themes
	optdepends = wlsunset: blue light filter for study profile
	optdepends = gamemode: CPU/GPU boost for gaming profile
